{
  "expo": {
    "name": "AnimeWatch",
    "slug": "anime-watch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "animewatch",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#1C1B1F",
    "primaryColor": "#6750A4",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8f854c32-d61c-4450-99ff-4eb1509b4fe6",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 30000
    },
    "extra": {
      "eas": {
        "projectId": "8f854c32-d61c-4450-99ff-4eb1509b4fe6"
      },
      "router": {}
    },
    "platforms": [
      "android",
      "ios"
    ],
    "ios": {
      "bundleIdentifier": "com.animewatch.app",
      "supportsTablet": true,
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "This app does not use the camera.",
        "NSPhotoLibraryUsageDescription": "Used to save screenshots from the app.",

        "UIBackgroundModes": [
          "audio",
          "fetch",
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.animewatch.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#1C1B1F",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.WAKE_LOCK",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ],
      "blockedPermissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_CONTACTS",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.READ_SMS",
        "android.permission.SEND_SMS",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_ADVERTISE",
        "android.permission.BLUETOOTH_CONNECT"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "animewatch",
              "host": "*",
              "pathPrefix": "/anime"
            },
            {
              "scheme": "animewatch",
              "host": "*",
              "pathPrefix": "/search"
            },
            {
              "scheme": "animewatch",
              "host": "*",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "allowBackup": false,
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1C1B1F",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 96,
          "resizeMode": "contain"
        }
      ],
      "expo-video",
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#6750A4",
          "sounds": [
            "./assets/sounds/notification.wav"
          ]
        }
      ],
      [
        "sentry-expo",
        {
          "organization": "animewatch",
          "project": "animewatch-mobile"
        }
      ],
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": false,
            "compileSdkVersion": 36,
            "targetSdkVersion": 36,
            "buildToolsVersion": "35.0.0",
            "minSdkVersion": 26,
            "kotlinVersion": "2.1.20",
            "packagingOptions": {
              "exclude": [
                "**/libjsc.so"
              ]
            },
            "proguardRules": "-keep class com.animewatch.** { *; }\n-keep class expo.modules.** { *; }\n-keep class com.swmansion.reanimated.** { *; }\n-dontwarn com.swmansion.reanimated.**\n-keep class org.jetbrains.skia.** { *; }\n-keep class com.facebook.hermes.** { *; }\n-keep class com.facebook.jni.** { *; }\n# Keep notification service\n-keep class * extends android.app.Service { *; }\n# Keep Expo modules\n-keep class * extends expo.modules.core.interfaces.ReactNativeHostHandler { *; }"
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "./src/config/withNetworkSecurityConfig"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
